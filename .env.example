# --- TwoFront runtime config (ADR-0009; supersedes parts of ADR-0004/0005) ---

# Internal / TEST-ONLY: wall-clock ms that represent one minute. NOT user-facing,
# NOT in Snapshot.config, NOT mutable via PATCH /api/config. Demo: 60000
# (1 minute = 60s). E2E sets a small value to compress the cadence. Defaults to
# 60000 if unset.
TICK_MS=60000

# Summary email fires every N minutes (int 1..100, default 1 ⇒ every minute,
# the brief's cadence). Runtime-mutable via the Time Controls slider.
EMAIL_SUMMARY_INTERVAL_MINUTES=1

# SMS Fibonacci gap = F(k) × this base, in minutes (int 1..100, default 1 ⇒ the
# unchanged 1,1,2,3,5,8… cadence). Runtime-mutable via the slider.
SMS_BASE_INTERVAL_MINUTES=1

# Every N days the SMS Fibonacci sequence restarts (int 1..100, default 1;
# internally 1 day = 1440 minutes). Runtime-mutable via the slider.
FIBONACCI_RESET_DAYS=1
