# --- TwoFront runtime config (ADR-0009; supersedes parts of ADR-0004/0005) ---

# TEST-ONLY time-compression; the app always uses 1 real minute — only the
# E2E overrides this. Wall-clock ms that represent one minute. NOT user-facing,
# NOT in Snapshot.config, NOT mutable via PATCH /api/config. The app always
# runs at 60000 (1 minute = 60s) and defaults to 60000 if unset; the E2E
# suite (and only the E2E suite) compresses it for deterministic test runs.
TICK_MS=60000

# Summary email fires every N minutes (int 1..100, default 1 ⇒ every minute,
# the brief's cadence). Runtime-mutable via the Time Controls slider.
EMAIL_SUMMARY_INTERVAL_MINUTES=1

# Every N days the SMS Fibonacci sequence restarts (int 1..100, default 1;
# internally 1 day = 1440 minutes). Runtime-mutable via the slider. (The SMS
# Fibonacci pace itself is NOT configurable — gaps are always F(k) minutes.)
FIBONACCI_RESET_DAYS=1
