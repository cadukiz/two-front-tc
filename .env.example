# --- TwoFront runtime config (ADR-0004 / ADR-0005) ---

# One scheduler tick = one simulated minute = TICK_MS milliseconds.
# Demo: 60000 (1 tick = 60s). E2E sets a small value to compress the cadence.
TICK_MS=60000

# Every N simulated minutes the SMS Fibonacci interval sequence restarts (1..100).
FIBONACCI_RESET_MINUTES=7

# Every N simulated minutes the email summary cycle counter advances (1..100).
# The summary cadence itself stays every 1 minute (brief intact).
EMAIL_RESET_MINUTES=7
